@model IEnumerable<Sohba.Application.DTOs.GroupAndPageAggregate.PageResponseDto>
@{
    ViewData["Title"] = "Pages";
}

<div class="max-w-7xl mx-auto page-transition">
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 mb-6">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-black text-gray-900">Pages</h1>
                <p class="text-gray-500 mt-1">Discover and follow pages</p>
            </div>
            <a asp-action="Create" class="px-4 py-2 bg-[#345e69] text-white font-semibold rounded-xl hover:bg-[#2a4b55] transition-colors flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Create Page
            </a>
        </div>
    </div>

    <div id="pagesGrid" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        @if (Model != null && Model.Any())
        {
            @* @foreach (var item in Model)
            {
                <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5 hover-lift">
                    <div class="flex items-start gap-4">
                        <div class="w-14 h-14 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-2xl flex items-center justify-center text-white text-xl font-bold">
                            @item.Name[0]
                        </div>
                        <div class="flex-1">
                            <h3 class="font-bold text-gray-900">@item.Name</h3>
                            <p class="text-gray-500 text-sm mt-1 line-clamp-2">@item.Description</p>
                            <p class="text-xs text-gray-400 mt-2">By @item.AdminName</p>
                        </div>
                    </div>
                    <button onclick="toggleFollow('@item.Id', this)" class="w-full mt-4 py-2 bg-slate-200 text-slate-600 font-semibold rounded-xl transition-colors">
                        Following
                    </button>
                </div>
            } *@

            @foreach (var item in Model)
            {
                <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5 hover-lift">
                    <div class="flex items-start gap-4">
                        <div class="w-14 h-14 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-2xl flex items-center justify-center text-white text-xl font-bold">
                            @item.Name[0]
                        </div>
                        <div class="flex-1">
                            <a href="/Pages/Details/@item.Id" class="font-bold text-gray-900 hover:text-emerald-600 transition">@item.Name</a>
                            <p class="text-gray-500 text-sm mt-1 line-clamp-2">@item.Description</p>
                            <p class="text-xs text-gray-400 mt-2">By @item.AdminName</p>
                        </div>
                    </div>

                    @if (item.AdminId == (Guid)ViewBag.CurrentUserId)
                    {
                        <a href="/Pages/Details/@item.Id" class="block text-center w-full mt-4 py-2 bg-emerald-50 text-emerald-600 font-bold rounded-xl outline-dashed outline-emerald-200 hover:bg-emerald-100 transition-colors">
                            ⚙️ Manage Your Page
                        </a>
                    }
                    else
                    {
                        @if (item.IsFollowing)
                        {
                            <button onclick="toggleFollow('@item.Id', this)" class="w-full mt-4 py-2 bg-slate-200 text-slate-600 font-semibold rounded-xl transition-colors">
                                Following
                            </button>
                        }
                        else
                        {
                            <button onclick="toggleFollow('@item.Id', this)" class="w-full mt-4 py-2 bg-[#345e69]/10 text-[#345e69] font-semibold rounded-xl hover:bg-[#345e69] hover:text-white transition-colors">
                                Follow
                            </button>
                        }
                    }
                </div>
            }

        }
        else
        {
            <div class="col-span-full text-center py-20">
                <div class="bg-slate-50 w-24 h-24 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-12 h-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                    </svg>
                </div>
                <h3 class="text-lg font-bold text-gray-900">No pages yet</h3>
                <p class="text-gray-500 mt-2">Create or follow a page!</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Handle Follow Action with JS for smooth UI experience
        async function followPage(pageId, btnElement) {
            try {
                const result = await SohbaApp.post('/Pages/Follow', { pageId });
                if (result.success) {
                    SohbaApp.toast('Page followed!', 'success');

                    btnElement.innerText = 'Following';
                    btnElement.classList.replace('bg-[#345e69]/10', 'bg-[#345e69]');
                    btnElement.classList.replace('text-[#345e69]', 'text-white');
                    btnElement.disabled = true;
                } else {
                    SohbaApp.toast(result.error || 'Failed to follow', 'error');
                }
            } catch (e) {
                SohbaApp.toast('Network error', 'error');
            }
        }
        // Handle Unfollow Action with JS for smooth UI experience
        async function toggleFollow(pageId, buttonElement) {
            const result = await SohbaApp.post('/Pages/ToggleFollow', { pageId });

            if (result.success) {
                if (result.isFollowing) {
                    buttonElement.innerText = "Following";
                    buttonElement.classList.replace('bg-[#345e69]/10', 'bg-slate-200');
                    buttonElement.classList.replace('text-[#345e69]', 'text-slate-600');
                    SohbaApp.toast('Page followed!', 'success');
                } else {
                    buttonElement.innerText = "Follow";
                    buttonElement.classList.replace('bg-slate-200', 'bg-[#345e69]/10');
                    buttonElement.classList.replace('text-slate-600', 'text-[#345e69]');
                    SohbaApp.toast('Unfollowed page', 'info');
                }
            } else {
                SohbaApp.toast(result.error || 'Failed action', 'error');
            }
        }

    </script>
}