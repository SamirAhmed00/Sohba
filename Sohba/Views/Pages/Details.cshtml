@model Sohba.Application.DTOs.GroupAndPageAggregate.PageResponseDto
@{
    ViewData["Title"] = Model.Name;
    Layout = "_AppLayout";
}

<div class="max-w-7xl mx-auto page-transition px-4">
    <!-- Page Header -->
    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden mb-6">
        <!-- Cover Image -->
        <div class="h-48 bg-gradient-to-r from-emerald-600 to-teal-600 relative">
            <div class="absolute -bottom-12 left-8">
                <div class="w-32 h-32 bg-white p-2 rounded-3xl shadow-lg">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" class="w-full h-full rounded-2xl object-cover" />
                    }
                    else
                    {
                        <div class="w-full h-full bg-slate-100 rounded-2xl flex items-center justify-center text-emerald-600 text-4xl font-black">
                            @Model.Name[0]
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Page Info & Actions -->
        <div class="pt-16 pb-6 px-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
            <div>
                <h1 class="text-3xl font-black text-gray-900">@Model.Name</h1>
                <p class="text-gray-500 mt-1 flex items-center gap-2">
                    <span>Created by @Model.AdminName</span>
                </p>
            </div>

            <div class="flex items-center gap-3">
                @* @if (User.Identity?.Name == Model.AdminName)
                { *@
                    <a asp-action="Edit" asp-route-id="@Model.Id"
                       class="px-5 py-2.5 bg-slate-100 text-gray-700 font-bold rounded-xl hover:bg-slate-200 transition-all flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                        Edit Page
                    </a>
                @* } *@

                <button onclick="toggleFollow()" id="followBtn"
                        class="px-5 py-2.5 bg-emerald-600 text-white font-bold rounded-xl hover:bg-emerald-700 transition-all flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                    <span>Follow Page</span>
                </button>
            </div>
        </div>

        <!-- Tabs -->
        <div class="px-8 border-t border-slate-50 flex gap-8">
            <button onclick="switchTab('posts')"
                    class="tab-btn active py-4 border-b-2 border-emerald-600 text-emerald-600 font-bold text-sm">
                Posts
            </button>
            <button onclick="switchTab('about')"
                    class="tab-btn py-4 border-b-2 border-transparent text-gray-400 hover:text-gray-600 font-bold text-sm">
                About
            </button>
            <button onclick="switchTab('followers')"
                    class="tab-btn py-4 border-b-2 border-transparent text-gray-400 hover:text-gray-600 font-bold text-sm">
                Followers
            </button>
        </div>
    </div>

    <!-- Tab Content -->
    <div id="tab-content">
        <!-- Posts Tab (default) -->
        <div id="posts-tab" class="tab-pane">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <div class="lg:col-span-2 space-y-6">
                    <!-- Create Post Box -->
                    @* @if (User.Identity?.Name == Model.AdminName)
                    { *@
                        <div class="bg-white rounded-2xl p-4 shadow-sm border border-slate-100 flex items-center gap-4">
                            <div class="w-10 h-10 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-600 font-bold">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                                </svg>
                            </div>
                            <a asp-controller="Posts" asp-action="Create" asp-route-pageId="@Model.Id"
                               class="flex-1 bg-slate-50 hover:bg-slate-100 text-left px-5 py-2.5 rounded-xl text-gray-500 transition-all border border-slate-100">
                                Share something with your page followers...
                            </a>
                        </div>
                    @* } *@

                    <!-- Posts Container -->
                    <div id="page-posts">
                        <div class="text-center py-10 text-gray-500">Loading posts...</div>
                    </div>
                </div>

                <!-- Right Sidebar -->
                <div class="space-y-6">
                    <!-- About Preview -->
                    <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
                        <h3 class="font-black text-gray-900 mb-4">About</h3>
                        <p class="text-gray-600 text-sm leading-relaxed">
                            @Model.Description
                        </p>
                        <div class="mt-6 pt-6 border-t border-slate-50">
                            <div class="flex items-center justify-between text-sm">
                                <span class="text-gray-400">Created</span>
                                <span class="font-bold text-gray-700">@Model.CreatedAt.ToString("MMMM dd, yyyy")</span> 
                            </div>
                        </div>
                    </div>

                    <!-- Followers Preview -->
                    <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
                        <div class="flex items-center justify-between mb-4">
                            <h3 class="font-black text-gray-900">Followers</h3>
                            <a href="#" onclick="switchTab('followers'); return false;" class="text-emerald-600 text-xs font-bold uppercase">View All</a>
                        </div>
                        <div id="followersPreview" class="grid grid-cols-5 gap-2">
                            
                            <div class="text-xs text-center text-slate-400 py-4 col-span-5">Loading...</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- About Tab -->
        <div id="about-tab" class="tab-pane hidden">
            <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100">
                <h2 class="text-2xl font-black text-gray-900 mb-6">About @Model.Name</h2>

                <div class="prose max-w-none">
                    <p class="text-gray-600 leading-relaxed whitespace-pre-line">
                        @Model.Description
                    </p>
                </div>

                <div class="mt-8 grid grid-cols-2 gap-4">
                    <div class="bg-slate-50 p-4 rounded-xl">
                        <span class="text-2xl font-black text-emerald-600" id="followersCount">0</span>
                        <span class="text-sm text-gray-600 block">Followers</span>
                    </div>
                    <div class="bg-slate-50 p-4 rounded-xl">
                        <span class="text-2xl font-black text-emerald-600" id="postsCount">0</span>
                        <span class="text-sm text-gray-600 block">Posts</span>
                    </div>
                </div>

                <div class="mt-6 pt-6 border-t border-slate-50">
                    <div class="flex items-center gap-2 text-sm text-gray-600">
                        <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                        <span>Admin: @Model.AdminName</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Followers Tab -->
        <div id="followers-tab" class="tab-pane hidden">
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
                <h2 class="text-lg font-black text-gray-900 mb-4">Followers</h2>
                <div id="followersList" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">

                    <div class="text-center text-gray-500 py-8 col-span-full">Loading followers...</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentPageId = '@Model.Id';
        let isFollowing = false;

        // Load page data
        document.addEventListener('DOMContentLoaded', function() {
            loadPagePosts();
            loadFollowersPreview();
            loadPageStats(); 
            checkFollowStatus();
        });

        async function loadPageStats() {
            try {
                const response = await fetch(`/Pages/GetPageStats?pageId=${currentPageId}`);
                const data = await response.json();
                
                if (data.success) {
                    document.getElementById('postsCount').textContent = data.postsCount;
                    document.getElementById('followersCount').textContent = data.followersCount;
                }
            } catch (error) {
                console.error('Error loading page stats:', error);
            }
        }

        // Switch tabs
        function switchTab(tab) {
            // Update tab buttons
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('active', 'border-emerald-600', 'text-emerald-600');
                btn.classList.add('border-transparent', 'text-gray-400');
            });
            event.target.classList.add('active', 'border-emerald-600', 'text-emerald-600');
            event.target.classList.remove('border-transparent', 'text-gray-400');

            // Show selected tab
            document.querySelectorAll('.tab-pane').forEach(pane => {
                pane.classList.add('hidden');
            });
            document.getElementById(`${tab}-tab`).classList.remove('hidden');

            // Load tab content if needed
            if (tab === 'followers') {
                loadAllFollowers();
            } else if (tab === 'about') {
                loadPageStats();
            }
        }

        // Load page posts
        async function loadPagePosts() {
            try {
                const response = await fetch(`/Pages/GetPagePosts?pageId=${currentPageId}`);
                const html = await response.text();
                document.getElementById('page-posts').innerHTML = html;
                
                const postsCount = document.querySelectorAll('#page-posts article').length;
                document.getElementById('postsCount').textContent = postsCount;
            } catch (error) {
                console.error('Error loading posts:', error);
                document.getElementById('page-posts').innerHTML = '<div class="text-center py-10 text-red-500">Failed to load posts</div>';
            }
        }

        // Load followers preview
        async function loadFollowersPreview() {
            try {
                const response = await fetch(`/Pages/GetFollowersPreview?pageId=${currentPageId}&count=10`);
                const followers = await response.json();

                const container = document.getElementById('followersPreview');
                if (followers && followers.length > 0) {
                    container.innerHTML = followers.map(f => `
                        <div class="group cursor-pointer" title="${f.userName}">
                            <img src="${f.profilePictureUrl || `https://ui-avatars.com/api/?name=${f.userName}&background=345e69&color=fff`}"
                                 class="w-10 h-10 rounded-xl object-cover group-hover:scale-105 transition-transform border-2 border-white shadow-sm" />
                        </div>
                    `).join('');

                    document.getElementById('followersCount').textContent = followers.length;
                } else {
                    container.innerHTML = '<div class="text-xs text-center text-slate-400 py-4 col-span-5">No followers yet</div>';
                }
            } catch (error) {
                console.error('Error loading followers:', error);
            }
        }

        // Load all followers
        async function loadAllFollowers() {
            try {
                const container = document.getElementById('followersList');
                container.innerHTML = '<div class="text-center text-gray-500 py-8 col-span-full">Loading followers...</div>';
                
                const response = await fetch(`/Pages/GetAllFollowers?pageId=${currentPageId}`);
                const data = await response.json();

                if (data.success && data.followers && data.followers.length > 0) {
                    container.innerHTML = data.followers.map(f => `
                        <div class="text-center group cursor-pointer">
                            <img src="${f.profilePictureUrl || `https://ui-avatars.com/api/?name=${f.userName}&background=345e69&color=fff`}"
                                 class="w-full aspect-square rounded-xl object-cover group-hover:scale-105 transition-transform border-2 border-white shadow-sm" />
                            <p class="text-xs font-semibold text-gray-700 mt-2 truncate">${f.userName}</p>
                            <p class="text-xs text-gray-400">Joined ${new Date(f.followedAt).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</p>
                        </div>
                    `).join('');
                } else {
                    container.innerHTML = '<div class="text-center text-gray-500 py-8 col-span-full">No followers yet</div>';
                }
            } catch (error) {
                console.error('Error loading followers:', error);
                document.getElementById('followersList').innerHTML = '<div class="text-center text-red-500 py-8 col-span-full">Failed to load followers</div>';
            }
        }

        // Check if current user follows this page
        async function checkFollowStatus() {
            try {
                const response = await fetch(`/Pages/CheckFollowStatus?pageId=${currentPageId}`);
                const data = await response.json();
                isFollowing = data.isFollowing;
                updateFollowButton();
            } catch (error) {
                console.error('Error checking follow status:', error);
            }
        }

        // Toggle follow
        async function toggleFollow() {
            try {
                const result = await SohbaApp.post('/Pages/ToggleFollow', { pageId: currentPageId });

                if (result.success) {
                    isFollowing = result.isFollowing;
                    updateFollowButton();
                    
                    SohbaApp.toast(isFollowing ? 'Page followed!' : 'Page unfollowed', 'success');
                    
                    await loadFollowersPreview();
                    await loadPageStats();
                    
                    if (!document.getElementById('followers-tab').classList.contains('hidden')) {
                        await loadAllFollowers();
                    }
                }
            } catch (error) {
                console.error('Error toggling follow:', error);
                SohbaApp.toast('Failed to update follow status', 'error');
            }
        }

        // Update follow button UI
        function updateFollowButton() {
            const btn = document.getElementById('followBtn');
            const icon = btn.querySelector('svg');
            const text = btn.querySelector('span');

            if (isFollowing) {
                btn.classList.remove('bg-emerald-600', 'hover:bg-emerald-700');
                btn.classList.add('bg-slate-200', 'hover:bg-slate-300', 'text-gray-700');
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />';
                text.textContent = 'Following';
            } else {
                btn.classList.remove('bg-slate-200', 'hover:bg-slate-300', 'text-gray-700');
                btn.classList.add('bg-emerald-600', 'hover:bg-emerald-700', 'text-white');
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />';
                text.textContent = 'Follow Page';
            }
        }
    </script>
}