@{
    ViewData["Title"] = "Logged Out";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full text-center">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8">
            <div class="w-20 h-20 bg-green-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
                <svg class="w-10 h-10 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
            </div>
            <h1 class="text-2xl font-black text-gray-900 mb-2">Logged Out Successfully</h1>
            <p class="text-gray-500 mb-6">You have been logged out of your account.</p>
            <a asp-action="Login"
               class="inline-block px-6 py-3 bg-[#345e69] text-white font-bold rounded-xl hover:bg-[#2a4b55] transition-colors">
                Sign In Again
            </a>
        </div>
    </div>
</div>