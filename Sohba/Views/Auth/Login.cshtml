@model Sohba.Application.DTOs.UserAggregate.LoginDto
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
        <!-- Header -->
        <div>
            <div class="flex justify-center">
                <div class="bg-[#345e69] w-16 h-16 flex items-center justify-center rounded-2xl shadow-lg">
                    <span class="text-white text-3xl font-black">S</span>
                </div>
            </div>
            <h2 class="mt-6 text-center text-3xl font-black text-gray-900">Welcome Back</h2>
            <p class="mt-2 text-center text-sm text-gray-600">
                Don't have an account?
                <a asp-action="Register" class="font-semibold text-[#345e69] hover:text-[#2a4b55] transition-colors">
                    Sign up
                </a>
            </p>
        </div>

        <!-- Login Form -->
        <form asp-action="Login" method="post" class="mt-8 space-y-6">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <div class="space-y-4">
                <!-- Email -->
                <div>
                    <label asp-for="Email" class="block text-sm font-bold text-gray-700 mb-2">Email Address</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                        </span>
                        <input asp-for="Email"
                               class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#345e69]/20 focus:border-[#345e69] transition-all"
                               placeholder="Enter your email" />
                    </div>
                    <span asp-validation-for="Email" class="text-red-500 text-xs mt-1"></span>
                </div>

                <!-- Password -->
                <div>
                    <label asp-for="Password" class="block text-sm font-bold text-gray-700 mb-2">Password</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                        </span>
                        <input asp-for="Password" type="password"
                               class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#345e69]/20 focus:border-[#345e69] transition-all"
                               placeholder="Enter your password" />
                    </div>
                    <span asp-validation-for="Password" class="text-red-500 text-xs mt-1"></span>
                </div>

                <!-- Remember Me & Forgot Password -->
                <div class="flex items-center justify-between">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input asp-for="RememberMe" type="checkbox" class="w-4 h-4 rounded border-gray-300 text-[#345e69] focus:ring-[#345e69]" />
                        <span class="text-sm text-gray-600">Remember me</span>
                    </label>

                    <a href="#" class="text-sm font-semibold text-[#345e69] hover:text-[#2a4b55] transition-colors">
                        Forgot password?
                    </a>
                </div>
            </div>

            <!-- Submit Button -->
            <button type="submit"
                    class="w-full py-3 bg-[#345e69] hover:bg-[#2a4b55] text-white font-bold rounded-xl shadow-lg shadow-[#345e69]/30 transform active:scale-95 transition-all">
                Sign In
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}