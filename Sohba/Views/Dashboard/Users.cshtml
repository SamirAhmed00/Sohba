@model Sohba.ViewModels.Dashboard.DashboardUsersViewModel
@{
    ViewData["Title"] = "Manage Users";
    // Layout = "~/Views/Shared/_Layout.cshtml";
    Layout = "_AppLayout";
}

<div class="max-w-7xl mx-auto page-transition">
    <!-- Header -->
    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 p-6 mb-6">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-black text-gray-900">Users</h1>
                <p class="text-gray-500 mt-1">Manage all users in the platform</p>
            </div>
            <div class="text-sm text-gray-500">
                Total: <span class="font-bold text-gray-900">@Model.TotalCount</span>
            </div>
        </div>

        <!-- Filters -->
        <div class="flex flex-wrap gap-4 mt-6">
            <div class="flex-1 min-w-[200px]">
                <div class="relative">
                    <input type="text"
                           id="searchInput"
                           value="@Model.SearchTerm"
                           placeholder="Search by name or email..."
                           class="w-full pl-10 pr-4 py-2 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#345e69]/20" />
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </span>
                </div>
            </div>
            <select id="statusFilter" class="px-4 py-2 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#345e69]/20">
                <option value="all" selected="@(Model.StatusFilter == "all")">All Users</option>
                <option value="active" selected="@(Model.StatusFilter == "active")">Active</option>
                <option value="blocked" selected="@(Model.StatusFilter == "blocked")">Blocked</option>
            </select>
            <button onclick="applyFilters()" class="px-6 py-2 bg-[#345e69] text-white font-semibold rounded-xl hover:bg-[#2a4b55] transition-colors">
                Apply Filters
            </button>
        </div>
    </div>

    <!-- Users Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50 border-b border-slate-200">
                    <tr>
                        <th class="px-6 py-4 text-left text-sm font-bold text-gray-600">User</th>
                        <th class="px-6 py-4 text-left text-sm font-bold text-gray-600">Email</th>
                        <th class="px-6 py-4 text-left text-sm font-bold text-gray-600">Joined</th>
                        <th class="px-6 py-4 text-left text-sm font-bold text-gray-600">Status</th>
                        <th class="px-6 py-4 text-left text-sm font-bold text-gray-600">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (Model.Users.Any())
                    {
                        @foreach (var user in Model.Users)
                        {
                            <tr class="hover:bg-slate-50 transition-colors" data-user-id="@user.Id">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <img src="@(user.ProfilePictureUrl ?? $"https://ui-avatars.com/api/?name={user.Name}&background=345e69&color=fff")"
                                             class="w-10 h-10 rounded-full object-cover" />
                                        <div>
                                            <div class="font-semibold text-gray-900">@user.Name</div>
                                            <div class="text-xs text-gray-500">ID: @user.Id.ToString().Substring(0, 8)...</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600">@user.Email</td>
                                <td class="px-6 py-4 text-sm text-gray-600">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="px-6 py-4">
                                    <span class="status-badge px-3 py-1 bg-green-100 text-green-700 text-xs font-bold rounded-full">Active</span>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-2">
                                        <button onclick="viewUser('@user.Id')" class="p-2 text-blue-600 hover:bg-blue-50 rounded-xl transition-colors" title="View">
                                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                            </svg>
                                        </button>
                                        <button onclick="blockUser('@user.Id')" class="p-2 text-orange-600 hover:bg-orange-50 rounded-xl transition-colors" title="Block">
                                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                                            </svg>
                                        </button>
                                        <button onclick="deleteUser('@user.Id')" class="p-2 text-red-600 hover:bg-red-50 rounded-xl transition-colors" title="Delete">
                                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                            </svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center text-gray-500">
                                No users found
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.TotalCount > Model.PageSize)
        {
            <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between">
                <div class="text-sm text-gray-500">
                    Showing @(((Model.CurrentPage - 1) * Model.PageSize) + 1) to @(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount)) of @Model.TotalCount users
                </div>
                <div class="flex gap-2">
                    @if (Model.CurrentPage > 1)
                    {
                        <a asp-action="Users" asp-route-page="@(Model.CurrentPage - 1)" asp-route-search="@Model.SearchTerm" asp-route-status="@Model.StatusFilter"
                           class="px-4 py-2 border border-slate-200 rounded-xl hover:bg-slate-50 transition-colors">
                            Previous
                        </a>
                    }
                    @if (Model.CurrentPage < (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize))
                    {
                        <a asp-action="Users" asp-route-page="@(Model.CurrentPage + 1)" asp-route-search="@Model.SearchTerm" asp-route-status="@Model.StatusFilter"
                           class="px-4 py-2 border border-slate-200 rounded-xl hover:bg-slate-50 transition-colors">
                            Next
                        </a>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- User Details Modal -->
<div id="userModal" class="fixed inset-0 z-[200] hidden">
    <div class="absolute inset-0 bg-black/60" onclick="closeUserModal()"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-lg rounded-2xl shadow-2xl overflow-hidden">
            <div class="flex items-center justify-between p-4 border-b">
                <h3 class="text-lg font-bold text-gray-900">User Details</h3>
                <button onclick="closeUserModal()" class="p-1 text-gray-400 hover:text-gray-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <div id="userModalContent" class="max-h-[70vh] overflow-y-auto">
                <!-- Content will be loaded here -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            
            var searchTimeout;

            document.addEventListener('DOMContentLoaded', function () {

                const searchInput = document.getElementById('searchInput');
                const statusFilter = document.getElementById('statusFilter');

                if (searchInput) {
                    searchInput.addEventListener('input', function () {
                        clearTimeout(searchTimeout);
                        searchTimeout = setTimeout(function () {
                            window.applyFilters();
                        }, 500);
                    });
                }

                if (statusFilter) {
                    statusFilter.addEventListener('change', function () {
                        window.applyFilters();
                    });
                }

            });

            // =========================
            // Filters
            // =========================
            window.applyFilters = function () {
                const search = document.getElementById('searchInput')?.value || '';
                const status = document.getElementById('statusFilter')?.value || '';

                window.location.href =
                    `/Dashboard/Users?search=${encodeURIComponent(search)}&status=${status}`;
            };

            // =========================
            // Block User
            // =========================
            async function blockUser(userId) {
                showConfirmModal({
                    title: 'Block User',
                    message: 'Are you sure you want to block this user? They will not be able to interact with the platform.',
                    type: 'warning',
                    confirmText: 'Block User',
                    onConfirm: async function() {
                        const result = await SohbaApp.post('/Dashboard/BlockUser', { userId });
                        if (result.success) {
                            SohbaApp.toast('User blocked successfully', 'success');

                            const badge = document.querySelector(`tr[data-user-id="${userId}"] .status-badge`);
                            badge.textContent = 'Blocked';
                            badge.className = 'status-badge px-3 py-1 bg-orange-100 text-orange-700 text-xs font-bold rounded-full';

                            const blockBtn = document.querySelector(`tr[data-user-id="${userId}"] button[onclick*="blockUser"]`);
                            blockBtn.outerHTML = `
                                <button onclick="unblockUser('${userId}')" class="p-2 text-green-600 hover:bg-green-50 rounded-xl transition-colors" title="Unblock">
                                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                                    </svg>
                                </button>
                            `;
                        } else {
                            SohbaApp.toast(result.error || 'Failed to block user', 'error');
                        }
                    }
                });
            }

            // =========================
            // Unblock User
            // =========================
            async function unblockUser(userId) {
                showConfirmModal({
                    title: 'Unblock User',
                    message: 'Are you sure you want to unblock this user? They will be able to interact with the platform again.',
                    type: 'info',
                    confirmText: 'Unblock User',
                    onConfirm: async function() {
                        const result = await SohbaApp.post('/Dashboard/UnblockUser', { userId });
                        if (result.success) {
                            SohbaApp.toast('User unblocked successfully', 'success');
                            const badge = document.querySelector(`tr[data-user-id="${userId}"] .status-badge`);
                            badge.textContent = 'Active';
                            badge.className = 'status-badge px-3 py-1 bg-green-100 text-green-700 text-xs font-bold rounded-full';
                        } else {
                            SohbaApp.toast(result.error || 'Failed to unblock user', 'error');
                        }
                    }
                });
            }

            // =========================
            // Delete User
            // =========================
            async function deleteUser(userId) {
                showConfirmModal({
                    title: 'Delete User',
                    message: 'Are you sure you want to delete this user? This action cannot be undone.',
                    type: 'delete',
                    confirmText: 'Delete User',
                    onConfirm: async function() {
                        const result = await SohbaApp.post('/Dashboard/DeleteUser', { userId });
                        if (result.success) {
                            SohbaApp.toast('User deleted successfully', 'success');
                            document.querySelector(`tr[data-user-id="${userId}"]`).remove();
                        } else {
                            SohbaApp.toast(result.error || 'Failed to delete user', 'error');
                        }
                    }
                });
            }

            // =========================
            // View User
            // =========================
            window.viewUser = async function (userId) {
                try {
                    const response = await fetch(`/Dashboard/GetUserDetails?userId=${userId}`);
                    const html = await response.text();

                    const modal = document.getElementById('userModal');
                    const content = document.getElementById('userModalContent');

                    if (!modal || !content) return;

                    content.innerHTML = html;
                    modal.classList.remove('hidden');
                    document.body.style.overflow = 'hidden';

                } catch (error) {
                    console.error(error);
                    SohbaApp.toast('Failed to load user details', 'error');
                }
            };

            window.closeUserModal = function () {
                const modal = document.getElementById('userModal');
                if (modal) modal.classList.add('hidden');
                document.body.style.overflow = '';
            };

        })();
    </script>
}
