@model Sohba.Application.DTOs.UserAggregate.UserResponseDto

<div class="p-6">
    <div class="flex items-center gap-4 mb-6">
        <img src="@(Model.ProfilePictureUrl ?? $"https://ui-avatars.com/api/?name={Model.Name}&background=345e69&color=fff")"
             class="w-20 h-20 rounded-full object-cover border-4 border-white shadow-lg" />
        <div>
            <h3 class="text-xl font-black text-gray-900">@Model.Name</h3>
            <p class="text-gray-500">@Model.Email</p>
            <p class="text-sm text-gray-400 mt-1">Joined @Model.CreatedAt.ToString("MMMM dd, yyyy")</p>
        </div>
    </div>

    <div class="grid grid-cols-2 gap-4 mb-6">
        <div class="bg-slate-50 p-4 rounded-xl">
            <span class="text-2xl font-black text-[#345e69]">0</span>
            <span class="text-sm text-gray-600 block">Friends</span>
        </div>
        <div class="bg-slate-50 p-4 rounded-xl">
            <span class="text-2xl font-black text-[#345e69]">0</span>
            <span class="text-sm text-gray-600 block">Posts</span>
        </div>
    </div>

    <div class="border-t border-slate-100 pt-4">
        <p class="text-sm text-gray-600"><span class="font-bold">Bio:</span> @(Model.Bio ?? "No bio")</p>
    </div>
</div>