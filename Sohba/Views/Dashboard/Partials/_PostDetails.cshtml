@model Sohba.Application.DTOs.PostAggregate.PostResponseDto

<div class="p-6">
    <div class="flex items-center gap-4 mb-4">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="w-20 h-20 rounded-xl object-cover" />
        }
        else
        {
            <div class="w-20 h-20 bg-slate-100 rounded-xl flex items-center justify-center text-slate-400 text-2xl">
                📝
            </div>
        }
        <div>
            <h3 class="text-xl font-black text-gray-900">@Model.Title</h3>
            <p class="text-sm text-gray-500">by @Model.AuthorName</p>
            <p class="text-xs text-gray-400 mt-1">@Model.CreatedAt.ToString("MMMM dd, yyyy HH:mm")</p>
        </div>
    </div>

    <div class="bg-slate-50 p-4 rounded-xl mb-4">
        <p class="text-gray-700 whitespace-pre-line">@Model.Content</p>
    </div>

    <div class="flex items-center gap-6 text-sm">
        <span class="flex items-center gap-1">
            <svg class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
            @Model.ReactionsCount Reactions
        </span>
        <span class="flex items-center gap-1">
            <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            @Model.CommentsCount Comments
        </span>
        <span class="px-3 py-1 bg-slate-100 text-slate-700 text-xs font-bold rounded-full">
            @Model.SourceType
        </span>
    </div>
</div>  