@model Sohba.Application.DTOs.PostAggregate.PostReportResponseDto

<div class="p-6">
    <div class="flex items-center gap-4 mb-6">
        <div class="w-14 h-14 bg-red-100 rounded-2xl flex items-center justify-center">
            <svg class="w-7 h-7 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
        </div>
        <div>
            <h3 class="text-xl font-black text-gray-900">Report Details</h3>
            <p class="text-sm text-gray-500">Reported by @Model.ReporterName</p>
            <p class="text-xs text-gray-400 mt-1">@Model.ReportedAt.ToString("MMMM dd, yyyy HH:mm")</p>
        </div>
    </div>

    <div class="bg-red-50 p-4 rounded-xl mb-4">
        <p class="text-sm text-red-700"><span class="font-bold">Reason:</span> @Model.Reason</p>
    </div>

    <div class="border-t border-slate-100 pt-4">
        <p class="text-sm text-gray-600"><span class="font-bold">Post ID:</span> @Model.PostId</p>
        <p class="text-sm text-gray-600 mt-1">
            <span class="font-bold">Status:</span>
            @if (Model.IsResolved)
            {
                <span class="text-green-600">Resolved</span>
            }
            else
            {
                <span class="text-red-600">Pending</span>
            }
        </p>
    </div>
</div>