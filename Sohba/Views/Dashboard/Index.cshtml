@model Sohba.ViewModels.Dashboard.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Charts JS -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="max-w-7xl mx-auto page-transition">
    <!-- Header -->
    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 p-6 mb-6">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-black text-gray-900">Dashboard</h1>
                <p class="text-gray-500 mt-1">Welcome back, Admin!</p>
            </div>
            <div class="flex items-center gap-3">
                <span class="px-4 py-2 bg-[#345e69]/10 text-[#345e69] rounded-xl font-semibold text-sm">
                    @DateTime.Now.ToString("dddd, MMMM dd, yyyy")
                </span>
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 mb-6">
        <!-- Total Users -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5 hover:shadow-lg transition-all duration-300 group">
            <div class="flex items-center justify-between mb-3">
                <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                    <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                    </svg>
                </div>
                <span class="text-sm font-medium text-green-600 bg-green-50 px-2.5 py-1 rounded-lg">+@(Model.NewUsersToday)</span>
            </div>
            <h3 class="text-2xl font-black text-gray-900">@Model.TotalUsers.ToString("N0")</h3>
            <p class="text-sm text-gray-500 mt-1">Total Users</p>
        </div>

        <!-- Total Posts -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5 hover:shadow-lg transition-all duration-300 group">
            <div class="flex items-center justify-between mb-3">
                <div class="w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                    <svg class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                </div>
                <span class="text-sm font-medium text-green-600 bg-green-50 px-2.5 py-1 rounded-lg">+@(Model.NewPostsToday)</span>
            </div>
            <h3 class="text-2xl font-black text-gray-900">@Model.TotalPosts.ToString("N0")</h3>
            <p class="text-sm text-gray-500 mt-1">Total Posts</p>
        </div>

        <!-- Total Groups -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5 hover:shadow-lg transition-all duration-300 group">
            <div class="flex items-center justify-between mb-3">
                <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                    <svg class="w-6 h-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                </div>
                <span class="text-sm font-medium text-green-600 bg-green-50 px-2.5 py-1 rounded-lg">+5%</span>
            </div>
            <h3 class="text-2xl font-black text-gray-900">@Model.TotalGroups.ToString("N0")</h3>
            <p class="text-sm text-gray-500 mt-1">Total Groups</p>
        </div>

        <!-- Total Pages -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-5 hover:shadow-lg transition-all duration-300 group">
            <div class="flex items-center justify-between mb-3">
                <div class="w-12 h-12 bg-teal-100 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                    <svg class="w-6 h-6 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                    </svg>
                </div>
            </div>
            <h3 class="text-2xl font-black text-gray-900">@Model.TotalPages.ToString("N0")</h3>
            <p class="text-sm text-gray-500 mt-1">Total Pages</p>
        </div>
    </div>

    <!-- Pending Reports Card (منفصلة) -->
    <div class="bg-gradient-to-r from-red-50 to-orange-50 rounded-2xl border border-red-100 p-6 mb-6">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
                <div class="w-14 h-14 bg-red-100 rounded-2xl flex items-center justify-center">
                    <svg class="w-7 h-7 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                </div>
                <div>
                    <h3 class="text-2xl font-black text-gray-900">@Model.PendingReports Pending Reports</h3>
                    <p class="text-red-600">Requires your attention</p>
                </div>
            </div>
            <a asp-action="Reports" class="px-6 py-3 bg-red-600 text-white font-bold rounded-xl hover:bg-red-700 transition-colors">
                View Reports
            </a>
        </div>
    </div>

    <!-- Charts & Recent Activity -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Users Chart (Last 7 Days) -->
        <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-black text-gray-900">User Activity</h2>
                <select class="px-3 py-1.5 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[#345e69]/20">
                    <option>Last 7 days</option>
                    <option>Last 30 days</option>
                    <option>Last 3 months</option>
                </select>
            </div>
            <div class="h-80">
                <canvas id="usersChart"></canvas>
            </div>
        </div>

        <!-- Recent Reports -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-black text-gray-900">Recent Reports</h2>
                <a asp-action="Reports" class="text-sm text-[#345e69] font-semibold hover:underline">View All</a>
            </div>
            <div class="space-y-4 max-h-96 overflow-y-auto">
                @if (Model.RecentReports.Any())
                {
                    @foreach (var report in Model.RecentReports)
                    {
                        <div class="flex items-start gap-3 p-3 hover:bg-slate-50 rounded-xl transition-colors">
                            <div class="w-8 h-8 bg-red-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                <svg class="w-4 h-4 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-semibold text-gray-900 truncate">@report.Reason</p>
                                <p class="text-xs text-gray-500">Reported @report.ReportedAt.ToString("MMM dd")</p>
                            </div>
                            <span class="text-xs px-2 py-1 bg-red-50 text-red-600 rounded-full">!</span>
                        </div>
                    }
                }
                else
                {
                    <p class="text-sm text-gray-500 text-center py-4">No pending reports</p>
                }
            </div>
        </div>

        <!-- Recent Users -->
        <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-black text-gray-900">Recent Users</h2>
                <a asp-action="Users" class="text-sm text-[#345e69] font-semibold hover:underline">View All</a>
            </div>
            <div class="space-y-4 max-h-96 overflow-y-auto">
                @if (Model.RecentUsers.Any())
                {
                    @foreach (var user in Model.RecentUsers)
                    {
                        <div class="flex items-center justify-between p-3 hover:bg-slate-50 rounded-xl transition-colors">
                            <div class="flex items-center gap-3">
                                <img src="@(user.ProfilePictureUrl ?? $"https://ui-avatars.com/api/?name={user.Name}&background=345e69&color=fff")"
                                     class="w-10 h-10 rounded-full object-cover" />
                                <div>
                                    <h3 class="font-semibold text-gray-900">@user.Name</h3>
                                    <p class="text-xs text-gray-500">@user.Email</p>
                                </div>
                            </div>
                            <span class="text-xs text-gray-400">@user.CreatedAt.ToString("MMM dd")</span>
                        </div>
                    }
                }
                else
                {
                    <p class="text-sm text-gray-500 text-center py-4">No users yet</p>
                }
            </div>
        </div>

        <!-- Recent Posts -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-black text-gray-900">Recent Posts</h2>
                <a asp-action="Posts" class="text-sm text-[#345e69] font-semibold hover:underline">View All</a>
            </div>
            <div class="space-y-4 max-h-96 overflow-y-auto">
                @if (Model.RecentPosts.Any())
                {
                    @foreach (var post in Model.RecentPosts)
                    {
                        <div class="flex items-start gap-3 p-3 hover:bg-slate-50 rounded-xl transition-colors">
                            @if (!string.IsNullOrEmpty(post.ImageUrl))
                            {
                                <img src="@post.ImageUrl" class="w-10 h-10 rounded-lg object-cover" />
                            }
                            else
                            {
                                <div class="w-10 h-10 bg-slate-100 rounded-lg flex items-center justify-center text-slate-400">
                                    📝
                                </div>
                            }
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-semibold text-gray-900 truncate">@post.Title</p>
                                <p class="text-xs text-gray-500">by @post.AuthorName · @post.CreatedAt.ToString("MMM dd")</p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-sm text-gray-500 text-center py-4">No posts yet</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Initialize Chart
        const ctx = document.getElementById('usersChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.Last7DaysLabels)),
                datasets: [{
                    label: 'New Users',
                    data: @Html.Raw(Json.Serialize(Model.UsersLast7Days)),
                    borderColor: '#345e69',
                    backgroundColor: 'rgba(52, 94, 105, 0.1)',
                    borderWidth: 3,
                    pointBackgroundColor: '#345e69',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                    pointRadius: 5,
                    pointHoverRadius: 7,
                    tension: 0.4,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: {
                            color: '#f1f5f9'
                        }
                    },
                    x: {
                        grid: {
                            display: false
                        }
                    }
                }
            }
        });
    </script>
}