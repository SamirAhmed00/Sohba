<!-- Three.js & GSAP -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

<style>
    :root {
        --brand-color: #345e69;
        --brand-light: #4a8291;
        --brand-dark: #2a4a52;
        --accent-color: #4a8291;
        --soft-bg: #f8fafc;
        --surface: #ffffff;
        --text-primary: #1e293b;
        --text-secondary: #64748b;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        background-color: var(--soft-bg);
        color: var(--text-primary);
        line-height: 1.6;
        overflow-x: hidden;
    }

    /* Custom Scrollbar */
    ::-webkit-scrollbar {
        width: 6px;
    }

    ::-webkit-scrollbar-track {
        background: transparent;
    }

    ::-webkit-scrollbar-thumb {
        background: var(--brand-color);
        border-radius: 3px;
    }

    /* Language Toggle Button */
    .lang-toggle {
        position: fixed;
        top: 24px;
        left: 24px;
        z-index: 100;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(52, 94, 105, 0.1);
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

        .lang-toggle:hover {
            background: var(--brand-color);
            color: white;
            transform: translateY(-2px);
        }

    /* Glass Header - Always LTR */
    .glass-header {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(52, 94, 105, 0.08);
        position: fixed;
        top: 0;
        width: 100%;
        z-index: 50;
        height: 72px;
    }

        .glass-header .nav-container {
            direction: ltr !important;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

    /* Logo Styles - Exact Match */
    .logo-link {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        cursor: pointer;
    }

    .logo-icon {
        width: 40px;
        height: 40px;
        background: var(--brand-color);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 900;
        font-size: 20px;
        box-shadow: 0 10px 15px -3px rgba(52, 94, 105, 0.3);
        transition: all 0.3s ease-in-out;
    }

    .logo-link:hover .logo-icon {
        transform: rotate(12deg) scale(1.1);
    }

    .logo-text {
        margin-left: 12px;
        font-size: 24px;
        font-weight: 900;
        letter-spacing: -0.025em;
        background: linear-gradient(to right, var(--brand-color) 0%, var(--brand-color) 20%, var(--brand-light) 100%);
        background-size: 200% auto;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        transition: all 0.3s ease;
        display: none;
    }

    @@media (min-width: 768px) {
        .logo-text {
            display: block;
        }
    }

    .logo-link:hover .logo-text {
        background-position: right center;
    }

    /* Auth Buttons */
    .auth-links {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .auth-link-login {
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 14px;
        font-weight: 700;
        transition: color 0.2s;
    }

        .auth-link-login:hover {
            color: var(--brand-color);
        }

    .auth-link-register {
        background: var(--brand-color);
        color: white;
        padding: 10px 24px;
        border-radius: 12px;
        text-decoration: none;
        font-size: 14px;
        font-weight: 700;
        transition: all 0.3s ease;
        box-shadow: 0 4px 6px -1px rgba(52, 94, 105, 0.2);
    }

        .auth-link-register:hover {
            background: var(--brand-light);
            transform: translateY(-1px);
            box-shadow: 0 10px 15px -3px rgba(52, 94, 105, 0.3);
        }

    /* Hero Section */
    .hero {
        min-height: 100vh;
        display: flex;
        align-items: center;
        padding-top: 72px;
        position: relative;
        background: radial-gradient(circle at top right, rgba(52, 94, 105, 0.05), transparent), radial-gradient(circle at bottom left, rgba(74, 130, 145, 0.05), transparent), linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
        overflow: hidden;
    }

    #canvas-container {
        position: absolute;
        inset: 0;
        opacity: 0.3;
        pointer-events: none;
    }

    .hero-content {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 24px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
        position: relative;
        z-index: 10;
    }

    .hero-text h1 {
        font-size: 56px;
        font-weight: 800;
        line-height: 1.1;
        color: var(--text-primary);
        margin-bottom: 24px;
        letter-spacing: -1.5px;
    }

    .hero-text .highlight {
        background: linear-gradient(to right, var(--brand-color), var(--brand-light));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
