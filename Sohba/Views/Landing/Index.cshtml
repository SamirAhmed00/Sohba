<script>
    gsap.registerPlugin(ScrollTrigger);

    // Language Toggle Logic
    let isArabic = true;
    function toggleLanguage() {
        isArabic = !isArabic;
        const mainContent = document.getElementById('mainContent');
        const langBtn = document.getElementById('langBtnText');

        // تبديل الاتجاه للمحتوى فقط
        mainContent.className = isArabic ? 'rtl-content' : 'ltr-content';
        langBtn.innerText = isArabic ? 'English' : 'العربية';

        // تبديل النصوص
        document.querySelectorAll('[data-ar]').forEach(el => {
            el.innerText = isArabic ? el.getAttribute('data-ar') : el.getAttribute('data-en');
        });
    }

    // GSAP Animations
    gsap.from(".hero-anim", { y: 40, opacity: 0, duration: 1.2, stagger: 0.15, ease: "power3.out" });

    const stats = document.querySelectorAll(".stat-num");
    stats.forEach(stat => {
        let target = parseInt(stat.getAttribute("data-target"));
        gsap.to(stat, {
            scrollTrigger: { trigger: stat, start: "top 90%" },
            innerHTML: target,
            duration: 2,
            snap: { innerHTML: 1 },
            ease: "expo.out"
        });
    });

    // Three.js
    const canvasContainer = document.getElementById('canvas-container');
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    canvasContainer.appendChild(renderer.domElement);
    const geometry = new THREE.BufferGeometry();
    const posArr = new Float32Array(80 * 3);
    for (let i = 0; i < 80 * 3; i++) posArr[i] = (Math.random() - 0.5) * 15;
    geometry.setAttribute('position', new THREE.BufferAttribute(posArr, 3));
    const points = new THREE.Points(geometry, new THREE.PointsMaterial({ color: 0x345e69, size: 0.1, transparent: true, opacity: 0.4 }));
    scene.add(points);
    camera.position.z = 5;
    function animate() { requestAnimationFrame(animate); points.rotation.y += 0.001; renderer.render(scene, camera); }
    animate();
</script>