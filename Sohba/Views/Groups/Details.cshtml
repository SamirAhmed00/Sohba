@model Sohba.ViewModels.Group.GroupDetailsViewModel
@{
    ViewData["Title"] = Model.Group.Name;
    Layout = "_AppLayout";
    var activeTab = ViewBag.ActiveTab ?? "posts";
}

<div class="max-w-7xl mx-auto page-transition px-4">
    <!-- Header -->
    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden mb-6">
        <div class="h-48 bg-gradient-to-r from-[#345e69] to-[#4a8291] relative">
            <div class="absolute -bottom-12 left-8">
                <div class="w-32 h-32 bg-white p-2 rounded-3xl shadow-lg">
                    @if (!string.IsNullOrEmpty(Model.Group.ImageUrl))
                    {
                        <img src="@Model.Group.ImageUrl" class="w-full h-full rounded-2xl object-cover" />
                    }
                    else
                    {
                        <div class="w-full h-full bg-slate-100 rounded-2xl flex items-center justify-center text-[#345e69] text-4xl font-black">
                            @Model.Group.Name[0]
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="pt-16 pb-6 px-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
            <div>
                <h1 class="text-3xl font-black text-gray-900">@Model.Group.Name</h1>
                <p class="text-gray-500 mt-1 flex items-center gap-2">
                    <span class="font-medium text-[#345e69]">@Model.Members.Count() Members</span>
                    <span>•</span>
                    <span>Created by @Model.Group.AdminName</span>
                </p>
            </div>

            <div class="flex items-center gap-3">
                @if (User.Identity?.Name == Model.Group.AdminName)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Group.Id" class="px-5 py-2.5 bg-slate-100 text-gray-700 font-bold rounded-xl hover:bg-slate-200 transition-all flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                        Edit Group
                    </a>
                }
                <button onclick="leaveGroup('@Model.Group.Id')" class="px-5 py-2.5 bg-red-50 text-red-600 font-bold rounded-xl hover:bg-red-100 transition-all">
                    Leave
                </button>

                @*We Will Comment The Upper Button Leave And Uncomment That -- In Testing *@
                @* @if (Model.Group.IsCurrentUserMember)
                {
                    <button onclick="leaveGroup('@Model.Group.Id')"
                            class="px-5 py-2.5 bg-red-50 text-red-600 font-bold rounded-xl hover:bg-red-100 transition-all">
                        Leave Group
                    </button>
                }
                else
                {
                    <button onclick="joinGroup('@Model.Group.Id')"
                            class="px-5 py-2.5 bg-[#345e69] text-white font-bold rounded-xl hover:bg-[#2a4b55] transition-all">
                        Join Group
                    </button>
                } *@
            </div>
        </div>

        <!-- Tabs -->
        <div class="px-8 border-t border-slate-50 flex gap-8">
            <button onclick="switchTab('posts')" class="py-4 border-b-2 border-[#345e69] text-[#345e69] font-bold text-sm">Posts</button>
            <button onclick="switchTab('members')" class="py-4 border-b-2 border-transparent text-gray-400 hover:text-gray-600 font-bold text-sm">Members</button>
            <button onclick="switchTab('about')" class="py-4 border-b-2 border-transparent text-gray-400 hover:text-gray-600 font-bold text-sm">About</button>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Column: Posts -->
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white rounded-2xl p-4 shadow-sm border border-slate-100 flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-[#345e69]/10 flex items-center justify-center text-[#345e69] font-bold">U</div>
                <button class="flex-1 bg-slate-50 hover:bg-slate-100 text-left px-5 py-2.5 rounded-xl text-gray-500 transition-all border border-slate-100">
                    Share something with the group...
                </button>
            </div>

            <div id="group-content-area">
                <partial name="Partials/_PostCard" model="ViewBag.Posts" />
            </div>
        </div>

        <!-- Right Column: About & Members -->
        <div class="space-y-6">
            <!-- About -->
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
                <h3 class="font-black text-gray-900 mb-4">About Community</h3>
                <p class="text-gray-600 text-sm leading-relaxed">
                    @Model.Group.Description
                </p>
                <div class="mt-6 pt-6 border-t border-slate-50 space-y-4">
                    <div class="flex items-center justify-between text-sm">
                        <span class="text-gray-400">Privacy</span>
                        <span class="font-bold text-gray-700">Public Group</span>
                    </div>
                </div>
            </div>

            <!-- Members (Preview) -->
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="font-black text-gray-900">Members (@Model.Members.Count())</h3>
                    <a href="#" class="text-[#345e69] text-xs font-bold uppercase">View All</a>
                </div>
                <div class="grid grid-cols-5 gap-2">
                    @foreach (var member in Model.Members.Take(10))
                    {
                        <div class="group cursor-pointer" title="@member.UserName (@member.Role)">
                            <img src="https://ui-avatars.com/api/?name=@member.UserName&background=345e69&color=fff"
                                 class="w-10 h-10 rounded-xl object-cover group-hover:scale-105 transition-transform border-2 border-white shadow-sm" />
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function switchTab(tab) {
            // Logic to switch tabs and maybe fetch data via AJAX
            SohbaApp.toast('Switching to ' + tab, 'info');
        }

        async function leaveGroup(groupId) {
            if(!confirm('Are you sure you want to leave this group?')) return;

            const result = await SohbaApp.post('/Groups/Leave', { groupId });
            if (result.success) {
                window.location.href = '/Groups';
            } else {
                SohbaApp.toast(result.error || 'Failed to leave group', 'error');
            }
        }
    </script>
}