    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
        <div class="flex justify-between items-center mb-4">
            <h3 class="font-bold text-gray-900 text-base">People You May Know</h3>
            <a asp-controller="Friends" asp-action="Suggestions" class="text-[#345e69] text-xs font-bold hover:underline">See All</a>
        </div>
        <div id="friendSuggestionsContainer" class="space-y-4">
            <div class="text-xs text-center text-slate-400 py-2">Loading suggestions...</div>
        </div>
    </div>

