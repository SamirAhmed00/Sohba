        <div>
            <div class="flex justify-between items-center px-2 mb-3">
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider">Groups To Join</h3>
                <a href="/Groups" class="text-xs text-[#345e69] hover:underline font-semibold">See All</a>
