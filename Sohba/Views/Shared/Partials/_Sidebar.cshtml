           class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Settings" ? "flex items-center px-4 py-3 text-[#345e69] bg-[#345e69]/10 rounded-xl transition-colors font-bold group" : "flex items-center px-4 py-3 text-gray-500 hover:bg-slate-50 hover:text-[#345e69] rounded-xl transition-all font-medium group")">
