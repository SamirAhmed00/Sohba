@* @model IEnumerable<Sohba.Application.DTOs.PostAggregate.PostResponseDto>
@{
    ViewData["Title"] = "Saved Posts";
}

<div class="max-w-4xl mx-auto page-transition">
    <!-- Header -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 mb-6 ">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-amber-100 rounded-2xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
                    </svg>
                </div>
                <div>
                    <h1 class="text-2xl font-black text-gray-900">Saved Posts</h1>
                    <p class="text-gray-500 mt-1">@Model.Count() posts saved</p>
                </div>
            </div>

            <!-- Filter -->
            <select class="px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#345e69]/20">
                <option value="all">All Posts</option>
                <option value="favorite">Favorites</option>
                <option value="watchlater">Watch Later</option>
                <option value="work">Work</option>
                <option value="education">Education</option>
            </select>
        </div>
    </div>

    <!-- Saved Posts Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        @foreach (var item in Model)
        {
            <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover-lift group">
                <div class="p-5">
                    <div class="flex items-start justify-between">
                        <div class="flex items-center gap-3">
                            <span class="px-3 py-1 bg-amber-100 text-amber-700 text-xs font-bold rounded-full uppercase">
                                Saved
                            </span>

                            @if (item.IsFavorite) 
                            {
                                <span class="px-3 py-1 bg-slate-100 text-slate-600 text-xs rounded-full">
                                    Favorite
                                </span>
                            }
                        </div>
                        <button onclick="unsavePost('@item.Id', event)" class="text-gray-400 hover:text-red-500 p-2 hover:bg-red-50 rounded-xl transition-colors">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                            </svg>
                        </button>
                    </div>

                    <h3 class="font-bold text-gray-900 mt-3 text-lg">@item.Title</h3>

                    <div class="flex items-center gap-2 mt-2 text-sm text-gray-500">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Saved @item.CreatedAt.ToString("MMM dd, yyyy")
                    </div>
                </div>

                <div class="px-5 pb-5 pt-2 border-t border-slate-100 flex gap-2">
                    <a asp-controller="Posts" asp-action="Details" asp-route-id="@item.Id" class="flex-1 py-2 bg-[#345e69] text-white text-center font-semibold rounded-xl hover:bg-[#2a4b55] transition-colors">
                        View Post
                    </a>
                    <button onclick="moveToCollection('@item.Id')" class="px-4 py-2 border border-slate-200 text-gray-600 rounded-xl hover:bg-slate-50 transition-colors">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z" />
                        </svg>
                    </button>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-20">
            <div class="bg-slate-50 w-24 h-24 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-12 h-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
                </svg>
            </div>
            <h3 class="text-lg font-bold text-gray-900">No saved posts</h3>
            <p class="text-gray-500 mt-2">Posts you save will appear here</p>
            <a asp-controller="Home" asp-action="Index" class="inline-block mt-4 px-6 py-2 bg-[#345e69] text-white font-semibold rounded-xl hover:bg-[#2a4b55] transition-colors">
                Browse Feed
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        async function unsavePost(postId, event) {
            if (!confirm('Remove from saved?')) return;
            try {
                const response = await fetch('/Posts/ToggleSavePost', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                    },
                    body: JSON.stringify({ postId, isFavorite: false })
                });
                const result = await response.json();
                if (result.success && !result.saved) {
                    window.SohbaApp.toast('Removed from saved', 'success');
                    const card = event.target.closest('.bg-white.rounded-2xl');
                    if (card) card.remove();
                } else {
                    window.SohbaApp.toast(result.error || 'Failed to remove', 'error');
                }
            } catch (e) {
                console.error(e);
                window.SohbaApp.toast('Network error', 'error');
            }
        }

        function moveToCollection(postId) {
            // Show dropdown or modal for collection selection
            SohbaApp.toast('Feature coming soon!', 'info');
        }
    </script>
} *@

@model IEnumerable<Sohba.Application.DTOs.PostAggregate.PostResponseDto>
@{
    ViewData["Title"] = "Saved Posts";
    var currentTag = ViewBag.CurrentTag ?? "all";
}

<div class="max-w-4xl mx-auto page-transition">
    <!-- Header -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 mb-6">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-amber-100 rounded-2xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
                    </svg>
                </div>
                <div>
                    <h1 class="text-2xl font-black text-gray-900">Saved Posts</h1>
                    <p class="text-gray-500 mt-1">@Model.Count() posts saved</p>
                </div>
            </div>


            <!-- Filter Dropdown -->
            <select id="tagFilter" onchange="filterByTag(this.value)" class="px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#345e69]/20">
                <option value="all" selected="@(currentTag == "all")">All Posts</option>
                <option value="Favorite" selected="@(currentTag == "Favorite")">⭐ Favorites</option>
                <option value="WatchLater" selected="@(currentTag == "WatchLater")">⏰ Watch Later</option>
                <option value="Work" selected="@(currentTag == "Work")">💼 Work</option>
                <option value="Education" selected="@(currentTag == "Education")">📚 Education</option>
                <option value="General" selected="@(currentTag == "General")">📁 General</option>
            </select>
        </div>
    </div>

    <!-- Saved Posts Grid -->
    @if (Model != null && Model.Any())
    {
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            @foreach (var post in Model)
            {
                <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden hover-lift group" data-post-id="@post.Id">
                    @if (!string.IsNullOrEmpty(post.ImageUrl))
                    {
                        <div class="h-48 overflow-hidden">
                            <img src="@post.ImageUrl" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                        </div>
                    }
                    
                    <div class="p-5">
                        <div class="flex items-start justify-between">
                            <div>
                                <span class="inline-flex items-center gap-1 px-3 py-1 bg-amber-100 text-amber-700 text-xs font-bold rounded-full">
                                    @switch(post.SavedTag)
                                    {
                                        case "Favorite":
                                            <span>⭐ Favorite</span>
                                            break;
                                        case "WatchLater":
                                            <span>⏰ Watch Later</span>
                                            break;
                                        case "Work":
                                            <span>💼 Work</span>
                                            break;
                                        case "Education":
                                            <span>📚 Education</span>
                                            break;
                                        default:
                                            <span>📁 Saved</span>
                                            break;
                                    }
                                </span>
                            </div>
                            
                            <div class="relative">
                                <button onclick="toggleMenu('@post.Id')" class="p-1 text-gray-400 hover:text-gray-600">
                                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
                                    </svg>
                                </button>
                                
                                <div id="menu-@post.Id" class="hidden absolute right-0 top-8 w-48 bg-white rounded-xl shadow-xl border border-slate-200 z-50 overflow-hidden">
                                    <div class="py-1">
                                        <button onclick="changeTag('@post.Id', 'General')" class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-slate-50">📁 General</button>
                                        <button onclick="changeTag('@post.Id', 'Favorite')" class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-slate-50">⭐ Favorite</button>
                                        <button onclick="changeTag('@post.Id', 'WatchLater')" class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-slate-50">⏰ Watch Later</button>
                                        <button onclick="changeTag('@post.Id', 'Work')" class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-slate-50">💼 Work</button>
                                        <button onclick="changeTag('@post.Id', 'Education')" class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-slate-50">📚 Education</button>
                                        <hr class="my-1">
                                        <button onclick="unsavePost('@post.Id')" class="w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50">Remove</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <h3 class="font-bold text-gray-900 mt-3 text-lg">@post.Title</h3>
                        
                        <p class="text-sm text-gray-600 mt-2 line-clamp-2">@post.Content</p>
                        
                        <div class="flex items-center gap-2 mt-4 text-xs text-gray-500">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <span>Saved @post.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </div>

                        <div class="flex items-center gap-2 mt-3">
                            <img src="https://ui-avatars.com/api/?name=@post.AuthorName&background=345e69&color=fff" class="w-6 h-6 rounded-full" />
                            <span class="text-xs text-gray-600">@post.AuthorName</span>
                        </div>

                        <div class="mt-4 pt-3 border-t border-slate-100">
                            <a asp-controller="Posts" asp-action="Details" asp-route-id="@post.Id" 
                               class="text-sm text-[#345e69] font-semibold hover:underline">
                                View Post →
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-20">
            <div class="bg-slate-50 w-24 h-24 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-12 h-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
                </svg>
            </div>
            <h3 class="text-lg font-bold text-gray-900">No saved posts</h3>
            <p class="text-gray-500 mt-2">Posts you save will appear here</p>
            <a asp-controller="Home" asp-action="Index" class="inline-block mt-4 px-6 py-2 bg-[#345e69] text-white font-semibold rounded-xl hover:bg-[#2a4b55] transition-colors">
                Browse Feed
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function filterByTag(tag) {
            window.location.href = tag === 'all' ? '/Posts/SavedPosts' : `/Posts/SavedPosts?tag=${tag}`;
        }
        
        function toggleMenu(postId) {
            document.querySelectorAll('[id^="menu-"]').forEach(m => m.classList.add('hidden'));
            document.getElementById(`menu-${postId}`).classList.toggle('hidden');
        }
        
        async function changeTag(postId, tag) {
            const result = await SohbaApp.post('/Posts/ChangeSavedPostTag', { postId, tag });
            if (result.success) {
                SohbaApp.toast(`Moved to ${tag}`, 'success');
                location.reload();
            }
        }
        
        async function unsavePost(postId) {
            if (!confirm('Remove from saved?')) return;
            const result = await SohbaApp.post('/Posts/RemoveSavedPost', { postId });
            if (result.success) {
                SohbaApp.toast('Removed from saved', 'success');
                document.querySelector(`[data-post-id="${postId}"]`).remove();
                
                // Update count
                const remainingCount = document.querySelectorAll('[data-post-id]').length;
                document.querySelector('.text-gray-500.mt-1').textContent = `${remainingCount} posts saved`;
            }
        }
        
        // Close menus when clicking outside
        document.addEventListener('click', function(e) {
            if (!e.target.closest('[id^="menu-"]') && !e.target.closest('button[onclick*="toggleMenu"]')) {
                document.querySelectorAll('[id^="menu-"]').forEach(menu => menu.classList.add('hidden'));
            }
        });
    </script>
}