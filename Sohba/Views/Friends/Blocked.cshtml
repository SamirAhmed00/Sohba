@model IEnumerable<Sohba.Application.DTOs.UserAggregate.FriendDto>
@{
    ViewData["Title"] = "Blocked Users";
}

<div class="max-w-4xl mx-auto page-transition">
    <!-- Header -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 mb-6">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-black text-gray-900">Blocked Users</h1>
                <p class="text-gray-500 mt-1">@Model.Count() blocked users</p>
            </div>
            <a asp-action="Index" class="px-4 py-2 bg-slate-100 text-gray-700 font-semibold rounded-xl hover:bg-slate-200 transition-colors">
                Back to Friends
            </a>
        </div>
    </div>

    <!-- Blocked Users List -->
    @if (Model != null && Model.Any())
    {
        <div class="space-y-3">
            @foreach (var user in Model)
            {
                <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-4" data-user-id="@user.FriendUserId">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-4">
                            <img src="@(user.ProfilePictureUrl ?? $"https://ui-avatars.com/api/?name={user.FriendName}&background=345e69&color=fff")"
                                 class="w-14 h-14 rounded-2xl object-cover border-2 border-slate-100" />
                            <div>
                                <h3 class="font-bold text-gray-900">@user.FriendName</h3>
                                <p class="text-sm text-gray-500">Blocked user</p>
                            </div>
                        </div>
                        <button onclick="unblockUser('@user.FriendUserId')"
                                class="px-5 py-2 bg-[#345e69] text-white font-semibold rounded-xl hover:bg-[#2a4b55] transition-colors">
                            Unblock
                        </button>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-20 bg-white rounded-2xl border border-slate-100">
            <div class="bg-slate-50 w-24 h-24 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-12 h-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                </svg>
            </div>
            <h3 class="text-lg font-bold text-gray-900">No blocked users</h3>
            <p class="text-gray-500 mt-2">You haven't blocked anyone</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        async function unblockUser(userId) {
            const result = await SohbaApp.post('/Friends/UnblockUser', { userId });
            if (result.success) {
                SohbaApp.toast('User unblocked', 'success');
                document.querySelector(`[data-user-id="${userId}"]`).remove();

                // Update count
                const remainingCount = document.querySelectorAll('[data-user-id]').length;
                document.querySelector('.text-gray-500.mt-1').textContent = `${remainingCount} blocked users`;
            }
        }
    </script>
}