@model Sohba.ViewModels.Friend.FriendRequestsViewModel
@{
    ViewData["Title"] = "Friend Requests";
    Layout = "_AppLayout";
}

<div class="max-w-7xl mx-auto page-transition">
    <!-- Header -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 mb-6">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-black text-gray-900">Friend Requests</h1>
                <p class="text-gray-500 mt-1">Manage your friend requests</p>
            </div>
            <a asp-action="Index" class="px-4 py-2 bg-slate-100 text-gray-700 font-semibold rounded-xl hover:bg-slate-200 transition-colors">
                Back to Friends
            </a>
        </div>
    </div>

    <!-- Tabs -->
    <div class="mb-6 border-b border-slate-200">
        <div class="flex gap-6">
            <button onclick="switchTab('pending')"
                    class="tab-btn active py-3 px-1 border-b-2 border-[#345e69] text-[#345e69] font-bold text-sm">
                Received (@Model.PendingCount)
            </button>
            <button onclick="switchTab('sent')"
                    class="tab-btn py-3 px-1 border-b-2 border-transparent text-gray-400 hover:text-gray-600 font-bold text-sm">
                Sent (@Model.SentCount)
            </button>
        </div>
    </div>

    <!-- Pending Requests Tab -->
    <div id="pending-tab" class="tab-content">
        @if (Model.PendingRequests != null && Model.PendingRequests.Any())
        {
            <div class="space-y-3">
                @foreach (var request in Model.PendingRequests)
                {
                    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-4 hover-lift" data-request-id="@request.FriendUserId">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-4">
                                <img src="@(request.ProfilePictureUrl ?? $"https://ui-avatars.com/api/?name={request.FriendName}&background=345e69&color=fff")"
                                     class="w-14 h-14 rounded-2xl object-cover border-2 border-slate-100" />
                                <div>
                                    <h3 class="font-bold text-gray-900">@request.FriendName</h3>
                                    <p class="text-sm text-gray-500">Wants to connect with you</p>
                                </div>
                            </div>
                            <div class="flex gap-2">
                                <button onclick="acceptRequest('@request.FriendUserId')"
                                        class="px-5 py-2 bg-[#345e69] text-white font-semibold rounded-xl hover:bg-[#2a4b55] transition-colors">
                                    Accept
                                </button>
                                <button onclick="rejectRequest('@request.FriendUserId')"
                                        class="px-5 py-2 border border-gray-200 text-gray-600 font-semibold rounded-xl hover:bg-gray-50 transition-colors">
                                    Decline
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-16 bg-white rounded-2xl border border-slate-100">
                <div class="bg-slate-50 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-10 h-10 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                    </svg>
                </div>
                <h3 class="text-lg font-bold text-gray-900">No pending requests</h3>
                <p class="text-gray-500 mt-2">You don't have any friend requests at the moment</p>
            </div>
        }
    </div>

    <!-- Sent Requests Tab (hidden by default) -->
    <div id="sent-tab" class="tab-content hidden">
        @if (Model.SentRequests != null && Model.SentRequests.Any())
        {
            <div class="space-y-3">
                @foreach (var request in Model.SentRequests)
                {
                    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-4" data-request-id="@request.FriendUserId">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-4">
                                <img src="@(request.ProfilePictureUrl ?? $"https://ui-avatars.com/api/?name={request.FriendName}&background=345e69&color=fff")"
                                     class="w-14 h-14 rounded-2xl object-cover border-2 border-slate-100" />
                                <div>
                                    <h3 class="font-bold text-gray-900">@request.FriendName</h3>
                                    <p class="text-sm text-gray-500">Request sent · Pending</p>
                                </div>
                            </div>
                            <button onclick="cancelRequest('@request.FriendUserId')"
                                    class="px-5 py-2 border border-red-200 text-red-600 font-semibold rounded-xl hover:bg-red-50 transition-colors">
                                Cancel Request
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-16 bg-white rounded-2xl border border-slate-100">
                <div class="bg-slate-50 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-10 h-10 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                    </svg>
                </div>
                <h3 class="text-lg font-bold text-gray-900">No sent requests</h3>
                <p class="text-gray-500 mt-2">You haven't sent any friend requests</p>
                <a asp-action="Suggestions" class="inline-block mt-4 px-6 py-2 bg-[#345e69] text-white font-semibold rounded-xl hover:bg-[#2a4b55] transition-colors">
                    Find Friends
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function switchTab(tab) {
            // Update tab buttons
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('active', 'border-[#345e69]', 'text-[#345e69]');
                btn.classList.add('border-transparent', 'text-gray-400');
            });

            event.target.classList.add('active', 'border-[#345e69]', 'text-[#345e69]');
            event.target.classList.remove('border-transparent', 'text-gray-400');

            // Show/hide tabs
            document.getElementById('pending-tab').classList.toggle('hidden', tab !== 'pending');
            document.getElementById('sent-tab').classList.toggle('hidden', tab !== 'sent');
        }

        async function acceptRequest(userId) {
            const result = await SohbaApp.post('/Friends/AcceptRequest', { requesterId: userId });
            if (result.success) {
                SohbaApp.toast('Friend request accepted!', 'success');
                document.querySelector(`[data-request-id="${userId}"]`).remove();

                // Update counts
                const countElement = document.querySelector('.tab-btn:first-child');
                const currentCount = parseInt(countElement.textContent.match(/\d+/)[0]);
                countElement.innerHTML = `Received (${currentCount - 1})`;
            }
        }

        async function rejectRequest(userId) {
            const result = await SohbaApp.post('/Friends/RejectRequest', { requesterId: userId });
            if (result.success) {
                SohbaApp.toast('Friend request declined', 'success');
                document.querySelector(`[data-request-id="${userId}"]`).remove();

                // Update counts
                const countElement = document.querySelector('.tab-btn:first-child');
                const currentCount = parseInt(countElement.textContent.match(/\d+/)[0]);
                countElement.innerHTML = `Received (${currentCount - 1})`;
            }
        }

        async function cancelRequest(userId) {
            if (!confirm('Cancel this friend request?')) return;

            const result = await SohbaApp.post('/Friends/CancelRequest', { receiverId: userId });
            if (result.success) {
                SohbaApp.toast('Request cancelled', 'success');
                document.querySelector(`[data-request-id="${userId}"]`).remove();

                // Update counts
                const countElement = document.querySelectorAll('.tab-btn')[1];
                const currentCount = parseInt(countElement.textContent.match(/\d+/)[0]);
                countElement.innerHTML = `Sent (${currentCount - 1})`;
            }
        }
    </script>
}